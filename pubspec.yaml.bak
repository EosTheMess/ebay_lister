name: ebay_lister
description: A new Flutter project for eBay listing.
version: 1.0.1+1

environment:
  sdk: '>=3.2.0 <4.0.0'

dependencies:
  flutter:
    sdk: flutter
  # Stable versions for early 2026
  camera: ^0.12.0
  path_provider: ^2.1.2
  path: ^1.9.0
  device_info_plus: ^12.3.0
  cupertino_icons: ^1.0.6

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^6.0.0

flutter:
  uses-material-design: true